# PythonAnywhere production configuration template.
# Copy this to .env on the server and replace every placeholder.
FLASK_ENV=production
DEBUG=false
DATABASE_URL=sqlite:////home/YOUR_USERNAME/webshield-scanner/instance/webshield.db
SECRET_KEY=replace-with-a-long-random-value
JWT_SECRET_KEY=replace-with-a-different-long-random-value
CORS_ORIGINS=https://YOUR_USERNAME.pythonanywhere.com,https://localhost,capacitor://localhost
SESSION_COOKIE_SECURE=true
RATELIMIT_STORAGE_URI=memory://
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-before-running-seed
